# ===== Supabase =====
# หาได้จาก Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# anon public key (ใช้สำหรับ login ในนามผู้ใช้)
SUPABASE_ANON_KEY=eyJhbGciOiJ...

# service_role key (ความลับ! ใช้ฝั่ง server เท่านั้น ห้าม commit)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...

# ===== Storage =====
# ชื่อ bucket สำหรับเก็บรูปหลักฐาน (สร้างใน schema.sql ให้แล้ว)
SUPABASE_STORAGE_BUCKET=proofs

# ===== App =====
PORT=4000

# โดเมนอีเมลที่อนุญาตให้ login (คั่นด้วย comma ได้)
ALLOWED_EMAIL_DOMAIN=siya.ac.th

# URL ของ frontend ที่อนุญาตให้เรียก API (CORS) คั่นด้วย comma
# ตัวอย่าง: http://localhost:5500,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
